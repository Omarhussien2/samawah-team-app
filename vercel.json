{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "crons": [
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/task-reminders",
      "schedule": "0 6 * * 0,2,4"
    },
    {
      "path": "/api/cron/task-update-reminders",
      "schedule": "0 6 * * 1,3"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 5 * * 0"
    }
  ]
}
